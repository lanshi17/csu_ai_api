# AI API 配置
# 支持的 SDK 格式: openai（OpenAI 及所有 OpenAI 兼容 API）

# API 提供商: openai
API_PROVIDER=openai

# API 密钥（统一使用一个 Key）
API_KEY=your-api-key-here

# API 基础 URL
API_BASE_URL=https://api.chat.csu.edu.cn/v1

# 模型名称
MODEL_NAME=DeepSeek-V4-Flash

# 速率限制配置
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# 对话配置
SYSTEM_PROMPT=你是一个有问必答的AI助手。
MAX_TOKENS=1024
TEMPERATURE=0.7
